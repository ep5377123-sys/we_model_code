# .env.example — Copy to .env and fill in real values. NEVER commit .env to git.

# Webhook Security
WEBHOOK_SECRET=your_long_random_secret_here

# Tradovate Credentials
TRADOVATE_USER=your_tradovate_username
TRADOVATE_PASS=your_tradovate_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_CID=your_client_id_number
TRADOVATE_SECRET=your_client_secret

# Environment: 'demo' for paper trading, 'live' for real money
# WARNING: NEVER set this to 'live' until you have tested thoroughly on demo.
TRADOVATE_ENV=demo

# Risk Guards
MAX_DAILY_ORDERS=20
MAX_DAILY_LOSS=500

# Server (Railway sets PORT automatically)
PORT=3000
