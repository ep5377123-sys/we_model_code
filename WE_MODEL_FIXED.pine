//@version=6
indicator("WE MODEL indicator", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

//==================================================================================================
//===================================== MODULE 1: IFVG (1m only) ==================================
//==================================================================================================

//----------------------- Settings
ifvg_disp_num   = input.int(5, maxval=100, minval=1, title="IFVG: Show Last",
     tooltip="Specifies the amount of most recent inversion FVG to display in Bullish/Bearish pairs, starting at the current and looking back.")
ifvg_signal_pref = input.string("Close", title="IFVG: Signal Preference", options=["Close","Wick"],
     tooltip="Choose to send signals based on Wicks or Close Price.")
ifvg_wt        = ifvg_signal_pref == "Wick"
ifvg_atr_multi = input.float(0.25, step=0.25, minval=0, title="IFVG: ATR Multiplier",
     tooltip="Filters FVGs based on ATR Width, Only displays Inversions that are Greater-Than the ATR*Multiplier.")

//----------------------- Colors
ifvg_green = input.color(color.new(#089981, 80), title="IFVG: Bull Color", group="IFVG Colors")
ifvg_red   = input.color(color.new(#f23645, 80), title="IFVG: Bear Color", group="IFVG Colors")
ifvg_gray  = input.color(#787b86,               title="IFVG: Midline Color", group="IFVG Colors")
ifvg_invis = color.rgb(0,0,0,100)

//----------------------- 1m only gate (for IFVG module only)
ifvg_only_1m = timeframe.isminutes and timeframe.multiplier == 1

//----------------------- UDTs
type IFVG_lab
    int x
    float y
    int dir

type IFVG_fvg
    int left = na
    float top = na
    int right = na
    float bot = na
    float mid = na
    int dir = na
    int state = na
    array<IFVG_lab> labs = na
    int x_val = na
    
//----------------------- ONLY SHOW IFVGs THAT ACTUALLY PRODUCED A SIGNAL
var IFVG_fvg[] ifvg_used_long_ary  = array.new<IFVG_fvg>()   // bullish IFVGs used for LONGS
var IFVG_fvg[] ifvg_used_short_ary = array.new<IFVG_fvg>()   // bearish IFVGs used for SHORTS

ifvg_trim_used(_ary) =>
    while _ary.size() > ifvg_disp_num
        _ary.shift()

ifvg_push_used(_ary, _value) =>
    _ary.push(_value)
    ifvg_trim_used(_ary)
//----------------------- IFVG Functions / State
ifvg_buffer = 100
ifvg_c_top = math.max(open, close)
ifvg_c_bot = math.min(open, close)

ifvg_label_maker(_x, _y, _dir) =>
    _lb = switch
        _dir == 1  => label.new(_x,_y,"\n▲", style=label.style_text_outline, color=ifvg_invis, textcolor=color.new(ifvg_green,0), size=size.small, xloc=xloc.bar_time)
        _dir == -1 => label.new(_x,_y,"▼\n", style=label.style_text_outline, color=ifvg_invis, textcolor=color.new(ifvg_red,0),   size=size.small, xloc=xloc.bar_time)
        => na
    _lb

ifvg_fvg_manage(_ary, _inv_ary) =>
    if _ary.size() >= ifvg_buffer
        _ary.shift()

    if _ary.size() > 0
        for i = _ary.size()-1 to 0
            value = _ary.get(i)
            _dir = value.dir

            if _dir == 1 and (ifvg_c_bot < value.bot)
                value.x_val := time
                _inv_ary.push(_ary.remove(i))
            if _dir == -1 and (ifvg_c_top > value.top)
                value.x_val := time
                _inv_ary.push(_ary.remove(i))

ifvg_inv_manage(_ary) =>
    fire = false
    if _ary.size() >= ifvg_buffer
        _ary.shift()
    if _ary.size() > 0
        for i = _ary.size()-1 to 0
            value = _ary.get(i)
            bx_top = value.top
            bx_bot = value.bot
            _dir = value.dir
            st = value.state

            if (st == 0 and _dir == 1)
                value.state := 1
                value.dir := -1
            if (_dir == -1 and st == 0)
                value.state := 1
                value.dir := 1
            if st >= 1
                value.right := time

            if (_dir == -1 and st == 1 and close < bx_bot and (ifvg_wt ? high : close[1]) >= bx_bot and (ifvg_wt ? high : close[1]) < bx_top)
                value.labs.push(IFVG_lab.new(time, bx_top, -1))
                fire := true

            if (_dir == 1 and st == 1 and close > bx_top and (ifvg_wt ? low : close[1]) <= bx_top and (ifvg_wt ? low : close[1]) > bx_bot)
                value.labs.push(IFVG_lab.new(time, bx_bot, 1))
                fire := true

            if st >= 1 and ((_dir == -1 and ifvg_c_top > bx_top) or (_dir == 1 and ifvg_c_bot < bx_bot))
                _ary.remove(i)

    fire

// Track IFVG module drawings so we don't delete other modules
var box[]   ifvg_boxes  = array.new_box()
var line[]  ifvg_lines  = array.new_line()
var label[] ifvg_labels = array.new_label()

ifvg_tiny_width = input.int(3, "IFVG: Tiny Width (bars)", minval=1, maxval=20,
     tooltip="How many 1m bars wide the displayed used IFVG should be.")

ifvg_clear_drawings() =>
    if array.size(ifvg_boxes) > 0
        for b in ifvg_boxes
            box.delete(b)
        array.clear(ifvg_boxes)
    if array.size(ifvg_lines) > 0
        for l in ifvg_lines
            line.delete(l)
        array.clear(ifvg_lines)
    if array.size(ifvg_labels) > 0
        for lb in ifvg_labels
            label.delete(lb)
        array.clear(ifvg_labels)

ifvg_send_it(_ary) =>
    last_index = _ary.size() - 1
    tiny_ms = ifvg_tiny_width * 60000

    for [index, value] in _ary
        bx_top  = value.top
        bx_bot  = value.bot
        bx_left = value.left
        xval    = value.x_val
        mid     = value.mid

        tiny_right = xval + tiny_ms

        col_left  = color.new(ifvg_gray, 78)
        col_right = color.new(ifvg_gray, 86)

        if index > last_index - ifvg_disp_num
            b1 = box.new(bx_left, bx_top, xval, bx_bot,
                 bgcolor=col_left, border_color=ifvg_invis, xloc=xloc.bar_time)
            array.push(ifvg_boxes, b1)

            b2 = box.new(xval, bx_top, tiny_right, bx_bot,
                 bgcolor=col_right, border_color=ifvg_invis, xloc=xloc.bar_time)
            array.push(ifvg_boxes, b2)

            ln = line.new(bx_left, mid, tiny_right, mid,
                 color=ifvg_gray, style=line.style_dashed, xloc=xloc.bar_time)
            array.push(ifvg_lines, ln)

            for stuff in value.labs
                lb = ifvg_label_maker(stuff.x, stuff.y, stuff.dir)
                if not na(lb)
                    array.push(ifvg_labels, lb)

//----------------------- IFVG Arrays
var IFVG_fvg[] ifvg_bull_fvg_ary = array.new<IFVG_fvg>()
var IFVG_fvg[] ifvg_bear_fvg_ary = array.new<IFVG_fvg>()

var IFVG_fvg[] ifvg_bull_inv_ary = array.new<IFVG_fvg>()
var IFVG_fvg[] ifvg_bear_inv_ary = array.new<IFVG_fvg>()

var int  ifvg_prev_bull_inv_size = 0
var int  ifvg_prev_bear_inv_size = 0
var bool ifvg_bull_created = false
var bool ifvg_bear_created = false


//----------------------- IFVG Logic (1m only)
if ifvg_only_1m
    ifvg_clear_drawings()

    ifvg_atr = nz(ta.atr(200) * ifvg_atr_multi, ta.cum(high - low) / (bar_index + 1))

    ifvg_fvg_up   = (low > high[2]) and (close[1] > high[2])
    ifvg_fvg_down = (high < low[2]) and (close[1] < low[2])

    if ifvg_fvg_up and math.abs(low - high[2]) > ifvg_atr
        array.push(ifvg_bull_fvg_ary, IFVG_fvg.new(time[1], low, time, high[2], math.avg(low, high[2]), 1, 0, array.new<IFVG_lab>(), na))

    if ifvg_fvg_down and math.abs(low[2] - high) > ifvg_atr
        array.push(ifvg_bear_fvg_ary, IFVG_fvg.new(time[1], low[2], time, high, math.avg(high, low[2]), -1, 0, array.new<IFVG_lab>(), na))

    ifvg_fvg_manage(ifvg_bull_fvg_ary, ifvg_bull_inv_ary)
    ifvg_fvg_manage(ifvg_bear_fvg_ary, ifvg_bear_inv_ary)

    // FIX: bull_created = bear_inv grew (bearish FVG inverted bullish), and vice versa
    ifvg_bear_created := ifvg_bull_inv_ary.size() > ifvg_prev_bull_inv_size
    ifvg_bull_created := ifvg_bear_inv_ary.size() > ifvg_prev_bear_inv_size

    ifvg_prev_bull_inv_size := ifvg_bull_inv_ary.size()
    ifvg_prev_bear_inv_size := ifvg_bear_inv_ary.size()

    ifvg_bear_signal = ifvg_inv_manage(ifvg_bull_inv_ary)
    ifvg_bull_signal = ifvg_inv_manage(ifvg_bear_inv_ary)

    if barstate.islast
        ifvg_send_it(ifvg_used_long_ary)
        ifvg_send_it(ifvg_used_short_ary)

// IFVG Alerts (Created)
alertcondition(ifvg_bull_created, "Bullish IFVG Created", "Bullish IFVG CREATED")
alertcondition(ifvg_bear_created, "Bearish IFVG Created", "Bearish IFVG CREATED")


//==================================================================================================
//============================== MODULE 2: LuxAlgo FVG (Deletes/Mitigation) ========================
//==================================================================================================

//----------------------- Settings
fvg_thresholdPer = input.float(0, "FVG: Threshold %", minval=0, maxval=100, step=.1, inline="fvg_threshold")
fvg_auto         = input.bool(false, "Auto", inline="fvg_threshold")
fvg_showLast     = input.int(0, "FVG: Unmitigated Levels", minval=0)
fvg_mitigationLv = input.bool(false, "FVG: Mitigation Levels")
fvg_tf           = input.timeframe("", "FVG: Timeframe")

// Style
fvg_extend  = input.int(20, "FVG: Extend", minval=0, inline="fvg_extend", group="FVG Style")
fvg_dynamic = input.bool(false, "Dynamic", inline="fvg_extend", group="FVG Style")

fvg_bullCss = input.color(color.new(#089981, 70), "Bullish FVG", group="FVG Style")
fvg_bearCss = input.color(color.new(#f23645, 70), "Bearish FVG", group="FVG Style")

// Dashboard
fvg_showDash = input.bool(false, "FVG: Show Dashboard", group="FVG Dashboard")
fvg_dashLoc  = input.string("Top Right", "Location", options=["Top Right", "Bottom Right", "Bottom Left"], group="FVG Dashboard")
fvg_textSize = input.string("Small", "Size", options=["Tiny", "Small", "Normal"], group="FVG Dashboard")

//----------------------- UDT
type FVG_rec
    float max
    float min
    bool  isbull
    int   t = time

//----------------------- Helpers
fvg_n = bar_index
method fvg_tosolid(color id) => color.rgb(color.r(id), color.g(id), color.b(id))

fvg_detect() =>
    var new_fvg = FVG_rec.new(na, na, false, na)
    threshold = fvg_auto ? ta.cum((high - low) / low) / bar_index : fvg_thresholdPer / 100.0

    bull_fvg = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
    bear_fvg = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold

    if bull_fvg
        new_fvg := FVG_rec.new(low, high[2], true)
    else if bear_fvg
        new_fvg := FVG_rec.new(low[2], high, false)

    [bull_fvg, bear_fvg, new_fvg]

//----------------------- Detection/Display (MTF)
var float fvg_max_bull = na, var float fvg_min_bull = na, var int fvg_bull_count = 0, var int fvg_bull_mitigated = 0
var float fvg_max_bear = na, var float fvg_min_bear = na, var int fvg_bear_count = 0, var int fvg_bear_mitigated = 0
var int fvg_t = 0

var FVG_rec[] fvg_records = array.new<FVG_rec>()
var box[]     fvg_areas   = array.new_box()

[fvg_bull_fvg, fvg_bear_fvg, fvg_new] = request.security(syminfo.tickerid, fvg_tf, fvg_detect(), lookahead=barmerge.lookahead_off)

// Bull
if fvg_bull_fvg and fvg_new.t != fvg_t
    if fvg_dynamic
        fvg_max_bull := fvg_new.max
        fvg_min_bull := fvg_new.min
    if not fvg_dynamic
        array.unshift(fvg_areas, box.new(fvg_n-2, fvg_new.max, fvg_n+fvg_extend, fvg_new.min, border_color=na, bgcolor=fvg_bullCss))
    array.unshift(fvg_records, fvg_new)
    fvg_bull_count += 1
    fvg_t := fvg_new.t
else if fvg_dynamic
    fvg_max_bull := math.max(math.min(close, fvg_max_bull), fvg_min_bull)

// Bear
if fvg_bear_fvg and fvg_new.t != fvg_t
    if fvg_dynamic
        fvg_max_bear := fvg_new.max
        fvg_min_bear := fvg_new.min
    if not fvg_dynamic
        array.unshift(fvg_areas, box.new(fvg_n-2, fvg_new.max, fvg_n+fvg_extend, fvg_new.min, border_color=na, bgcolor=fvg_bearCss))
    array.unshift(fvg_records, fvg_new)
    fvg_bear_count += 1
    fvg_t := fvg_new.t
else if fvg_dynamic
    fvg_min_bear := math.min(math.max(close, fvg_min_bear), fvg_max_bear)

// Mitigation test + delete
if fvg_records.size() > 0
    for i = fvg_records.size()-1 to 0
        get = fvg_records.get(i)

        if get.isbull
            if (low <= get.max and high >= get.min) and time > get.t
                if fvg_mitigationLv
                    line.new(get.t, get.min, time, get.min, xloc=xloc.bar_time, color=fvg_bullCss, style=line.style_dashed)

                if not fvg_dynamic
                    area = fvg_areas.remove(i)
                    box.delete(area)

                fvg_records.remove(i)
                fvg_bull_mitigated += 1
        else
            if (low <= get.max and high >= get.min) and time > get.t
                if fvg_mitigationLv
                    line.new(get.t, get.max, time, get.max, xloc=xloc.bar_time, color=fvg_bearCss, style=line.style_dashed)

                if not fvg_dynamic
                    area = fvg_areas.remove(i)
                    box.delete(area)

                fvg_records.remove(i)
                fvg_bear_mitigated += 1

// Unmitigated lines
var line[] fvg_unmitigated = array.new_line()

if barstate.islast and fvg_showLast > 0 and fvg_records.size() > 0
    if fvg_unmitigated.size() > 0
        for element in fvg_unmitigated
            line.delete(element)
        fvg_unmitigated.clear()

    for i = 0 to math.min(fvg_showLast-1, fvg_records.size()-1)
        get = fvg_records.get(i)
        fvg_unmitigated.push(line.new(get.t,
           get.isbull ? get.min : get.max,
           time,
           get.isbull ? get.min : get.max,
           xloc=xloc.bar_time,
           color=get.isbull ? fvg_bullCss : fvg_bearCss))

// Dashboard
var table_position = fvg_dashLoc == "Bottom Left" ? position.bottom_left : fvg_dashLoc == "Top Right" ? position.top_right : position.bottom_right
var table_size = fvg_textSize == "Tiny" ? size.tiny : fvg_textSize == "Small" ? size.small : size.normal

var table fvg_tb = table.new(table_position, 3, 3, bgcolor=#1e222d, border_color=#373a46, border_width=1, frame_color=#373a46, frame_width=1)

if fvg_showDash
    if barstate.isfirst
        table.cell(fvg_tb, 1, 0, "Bullish", text_color=fvg_tosolid(fvg_bullCss), text_size=table_size)
        table.cell(fvg_tb, 2, 0, "Bearish", text_color=fvg_tosolid(fvg_bearCss), text_size=table_size)
        table.cell(fvg_tb, 0, 1, "Count", text_size=table_size, text_color=color.white)
        table.cell(fvg_tb, 0, 2, "Mitigated", text_size=table_size, text_color=color.white)

    if barstate.islast
        table.cell(fvg_tb, 1, 1, str.tostring(fvg_bull_count), text_color=fvg_tosolid(fvg_bullCss), text_size=table_size)
        table.cell(fvg_tb, 2, 1, str.tostring(fvg_bear_count), text_color=fvg_tosolid(fvg_bearCss), text_size=table_size)

        table.cell(fvg_tb, 1, 2, str.tostring(fvg_bull_count == 0 ? 0 : (fvg_bull_mitigated / fvg_bull_count) * 100, format.percent),
            text_color=fvg_tosolid(fvg_bullCss), text_size=table_size)
        table.cell(fvg_tb, 2, 2, str.tostring(fvg_bear_count == 0 ? 0 : (fvg_bear_mitigated / fvg_bear_count) * 100, format.percent),
            text_color=fvg_tosolid(fvg_bearCss), text_size=table_size)

// Dynamic fills
max_bull_plot = plot(fvg_max_bull, color=na)
min_bull_plot = plot(fvg_min_bull, color=na)
fill(max_bull_plot, min_bull_plot, color=fvg_bullCss)

max_bear_plot = plot(fvg_max_bear, color=na)
min_bear_plot = plot(fvg_min_bear, color=na)
fill(max_bear_plot, min_bear_plot, color=fvg_bearCss)

// FVG Alerts
alertcondition(fvg_bull_count > fvg_bull_count[1], "Bullish FVG", "Bullish FVG detected")
alertcondition(fvg_bear_count > fvg_bear_count[1], "Bearish FVG", "Bearish FVG detected")
alertcondition(fvg_bull_mitigated > fvg_bull_mitigated[1], "Bullish FVG Mitigation", "Bullish FVG mitigated")
alertcondition(fvg_bear_mitigated > fvg_bear_mitigated[1], "Bearish FVG Mitigation", "Bearish FVG mitigated")


//==================================================================================================
//=========================== MODULE 3: 15m Reversal Highs & Lows (Wick-Anchored) ===================
//==================================================================================================

// Inputs
hl_enabled       = input.bool(true,  "15m HL: Enable")
hl_keepN         = input.int(80,     "15m HL: Keep Last N Levels", minval=1)
hl_lineColorH    = input.color(color.fuchsia, "15m HL: High Color")
hl_lineColorL    = input.color(color.aqua,    "15m HL: Low Color")
hl_lineWidth     = input.int(1,      "15m HL: Line Width", minval=1)
hl_extendBars    = input.int(40,     "15m HL: Extend Right (Bars)", minval=0)
hl_showLabels    = input.bool(true,  "15m HL: Show Price Labels")
hl_deleteOnTouch = input.bool(true,  "15m HL: Delete On Touch")

hl_barMs = timeframe.in_seconds(timeframe.period) * 1000

// 15m boundary on chart timeframe
hl_t15   = time("15")
hl_new15 = ta.change(hl_t15) != 0

// 15m open/close for candle direction (non-repainting)
hl_o15 = request.security(syminfo.tickerid, "15", open,  lookahead=barmerge.lookahead_off)
hl_c15 = request.security(syminfo.tickerid, "15", close, lookahead=barmerge.lookahead_off)

// Track wick times inside each 15m candle
var float hl_curLow  = na
var int   hl_curLowT = na
var float hl_curHigh = na
var int   hl_curHighT= na

var float hl_p1Low   = na
var int   hl_p1LowT  = na
var float hl_p1High  = na
var int   hl_p1HighT = na

var float hl_p2Low   = na
var int   hl_p2LowT  = na
var float hl_p2High  = na
var int   hl_p2HighT = na

if na(hl_curLow) or hl_new15
    hl_curLow   := low
    hl_curLowT  := time
    hl_curHigh  := high
    hl_curHighT := time
else
    if low < hl_curLow
        hl_curLow  := low
        hl_curLowT := time
    if high > hl_curHigh
        hl_curHigh  := high
        hl_curHighT := time

if hl_new15
    hl_p2Low   := hl_p1Low
    hl_p2LowT  := hl_p1LowT
    hl_p2High  := hl_p1High
    hl_p2HighT := hl_p1HighT

    hl_p1Low   := hl_curLow
    hl_p1LowT  := hl_curLowT
    hl_p1High  := hl_curHigh
    hl_p1HighT := hl_curHighT

// Storage for drawings
var line[]  hl_hiLines = array.new_line()
var line[]  hl_loLines = array.new_line()
var label[] hl_hiLabs  = array.new_label()
var label[] hl_loLabs  = array.new_label()

// Counters (for alerts)
var int hl_highCreatedCount   = 0
var int hl_lowCreatedCount    = 0
var int hl_highMitigatedCount = 0
var int hl_lowMitigatedCount  = 0

hl_trim(_lines, _labs) =>
    if array.size(_lines) > hl_keepN
        line.delete(array.shift(_lines))
    if hl_showLabels and array.size(_labs) > hl_keepN
        label.delete(array.shift(_labs))

hl_addLevel(_isHigh, _x1, _y, _x2) =>
    col = _isHigh ? hl_lineColorH : hl_lineColorL
    ln  = line.new(_x1, _y, _x2, _y, xloc=xloc.bar_time, color=col, width=hl_lineWidth)

    if _isHigh
        array.push(hl_hiLines, ln)
    else
        array.push(hl_loLines, ln)

    if hl_showLabels
        lb = label.new(_x2, _y, str.tostring(_y), xloc=xloc.bar_time,
            style=label.style_label_left,
            textcolor=col,
            color=color.new(color.black, 100),
            size=size.small)

        if _isHigh
            array.push(hl_hiLabs, lb)
        else
            array.push(hl_loLabs, lb)

// Create levels once per 15m close
hl_l15 = request.security(syminfo.tickerid, "15", low,  barmerge.gaps_off, barmerge.lookahead_off)
hl_h15 = request.security(syminfo.tickerid, "15", high, barmerge.gaps_off, barmerge.lookahead_off)
hl_p15 = request.security(syminfo.tickerid, "15", time, barmerge.gaps_off, barmerge.lookahead_off)

if hl_enabled and hl_new15 and not na(hl_p2Low) and not na(hl_p1Low)
    bear2 = hl_c15[2] < hl_o15[2]
    bull2 = hl_c15[2] > hl_o15[2]
    bear1 = hl_c15[1] < hl_o15[1]
    bull1 = hl_c15[1] > hl_o15[1]

    // FIX: compute x2 using integer cast to avoid type mismatch
    int x2 = hl_extendBars > 0 ? int(time + hl_extendBars * hl_barMs) : time

    // LOW: bearish [2] then bullish [1] -> true lowest wick
    if bear2 and bull1
        float yLow = math.min(hl_l15[2], hl_l15[1])
        int   xLow = hl_l15[2] <= hl_l15[1] ? hl_p15[2] : hl_p15[1]
        hl_addLevel(false, xLow, yLow, x2)
        hl_trim(hl_loLines, hl_loLabs)
        hl_lowCreatedCount += 1  // FIX: was never incremented — alerts were broken

    // HIGH: bullish [2] then bearish [1] -> true highest wick
    if bull2 and bear1
        float yHigh = math.max(hl_h15[2], hl_h15[1])
        int   xHigh = hl_h15[2] >= hl_h15[1] ? hl_p15[2] : hl_p15[1]
        hl_addLevel(true, xHigh, yHigh, x2)
        hl_trim(hl_hiLines, hl_hiLabs)
        hl_highCreatedCount += 1  // FIX: was never incremented — alerts were broken

// FIX: removed duplicate `endX` declaration — only one typed int declaration kept here
int endX = time + hl_extendBars * hl_barMs

// Extend lines/labels to the right
if hl_enabled and barstate.islast and hl_extendBars > 0
    if array.size(hl_hiLines) > 0
        for i = 0 to array.size(hl_hiLines) - 1
            line.set_x2(array.get(hl_hiLines, i), endX)

    if array.size(hl_loLines) > 0
        for i = 0 to array.size(hl_loLines) - 1
            line.set_x2(array.get(hl_loLines, i), endX)

    if hl_showLabels
        if array.size(hl_hiLabs) > 0
            for i = 0 to array.size(hl_hiLabs) - 1
                label.set_x(array.get(hl_hiLabs, i), endX)

        if array.size(hl_loLabs) > 0
            for i = 0 to array.size(hl_loLabs) - 1
                label.set_x(array.get(hl_loLabs, i), endX)

//------------------------- Delete On Touch (Mitigation)
if hl_enabled and hl_deleteOnTouch

    //================ HIGH LINES =================
    if array.size(hl_hiLines) > 0
        for i = array.size(hl_hiLines) - 1 to 0
            ln  = array.get(hl_hiLines, i)
            lvl = line.get_y1(ln)

            crossedHigh = (high >= lvl) and (high[1] < lvl)

            if crossedHigh
                line.delete(ln)
                array.remove(hl_hiLines, i)

                if hl_showLabels and i < array.size(hl_hiLabs)
                    lb = array.get(hl_hiLabs, i)
                    label.delete(lb)
                    array.remove(hl_hiLabs, i)

                hl_highMitigatedCount += 1

    //================ LOW LINES =================
    if array.size(hl_loLines) > 0
        for i = array.size(hl_loLines) - 1 to 0
            ln  = array.get(hl_loLines, i)
            lvl = line.get_y1(ln)

            crossedLow = (low <= lvl) and (low[1] > lvl)

            if crossedLow
                line.delete(ln)
                array.remove(hl_loLines, i)

                if hl_showLabels and i < array.size(hl_loLabs)
                    lb = array.get(hl_loLabs, i)
                    label.delete(lb)
                    array.remove(hl_loLabs, i)

                hl_lowMitigatedCount += 1

// HL Alerts
alertcondition(hl_highCreatedCount > hl_highCreatedCount[1], "15m High Created", "New 15m High Level Created")
alertcondition(hl_lowCreatedCount > hl_lowCreatedCount[1],   "15m Low Created",  "New 15m Low Level Created")
alertcondition(hl_highMitigatedCount > hl_highMitigatedCount[1], "15m High Mitigated", "15m High Level Mitigated")
alertcondition(hl_lowMitigatedCount > hl_lowMitigatedCount[1],   "15m Low Mitigated",  "15m Low Level Mitigated")

//==================================================================================================
//================================== WE MODEL SETUP ENGINE ========================================
//==================================================================================================

//------------------------- Inputs
we_recent_ms       = input.int(15, "WE MODEL: Valid window (minutes)", minval=1, group="WE MODEL") * 60 * 1000
we_cooldown_bars   = input.int(5, "WE MODEL: Cooldown (bars)", minval=0, group="WE MODEL")

//------------------------- Track last 1m FVG boundaries
var float we_lastBearFvgTop_1m = na
var float we_lastBullFvgBot_1m = na

//------------------------- Track last sweep/tap timestamps
var int we_lastSweepLowTime  = na
var int we_lastSweepHighTime = na
var int we_lastTapBullTime   = na
var int we_lastTapBearTime   = na

//------------------------- 1m FVG tracking
we_fvg_up_1m   = (low > high[2]) and (close[1] > high[2])
we_fvg_down_1m = (high < low[2]) and (close[1] < low[2])

if timeframe.isminutes and timeframe.multiplier == 1
    if we_fvg_down_1m
        we_lastBearFvgTop_1m := low[2]
    if we_fvg_up_1m
        we_lastBullFvgBot_1m := high[2]

//------------------------- 15m FVG TAP (LIVE ON 1m, NO WAITING FOR 15m CLOSE)

var float we_lastBull15Top = na
var float we_lastBull15Bot = na
var int   we_lastBull15Time = na

var float we_lastBear15Top = na
var float we_lastBear15Bot = na
var int   we_lastBear15Time = na

we_bull15_new = request.security(
    syminfo.tickerid, "15",
    (low > high[2]) and (close[1] > high[2]),
    lookahead = barmerge.lookahead_off
)

we_bear15_new = request.security(
    syminfo.tickerid, "15",
    (high < low[2]) and (close[1] < low[2]),
    lookahead = barmerge.lookahead_off
)

we_bull15_top = request.security(syminfo.tickerid, "15", low,     lookahead = barmerge.lookahead_off)
we_bull15_bot = request.security(syminfo.tickerid, "15", high[2], lookahead = barmerge.lookahead_off)

we_bear15_top = request.security(syminfo.tickerid, "15", low[2],  lookahead = barmerge.lookahead_off)
we_bear15_bot = request.security(syminfo.tickerid, "15", high,    lookahead = barmerge.lookahead_off)

we_fvg15_time = request.security(syminfo.tickerid, "15", time,    lookahead = barmerge.lookahead_off)

if we_bull15_new
    we_lastBull15Top  := we_bull15_top
    we_lastBull15Bot  := we_bull15_bot
    we_lastBull15Time := we_fvg15_time

if we_bear15_new
    we_lastBear15Top  := we_bear15_top
    we_lastBear15Bot  := we_bear15_bot
    we_lastBear15Time := we_fvg15_time

we_tapBullFvg_15m_live = not na(we_lastBull15Top) and not na(we_lastBull15Bot) and time > we_lastBull15Time and (low <= we_lastBull15Top and high >= we_lastBull15Bot)
we_tapBearFvg_15m_live = not na(we_lastBear15Top) and not na(we_lastBear15Bot) and time > we_lastBear15Time and (low <= we_lastBear15Top and high >= we_lastBear15Bot)

// FIX: gate tap signals to 1m only so they don't misfire on other timeframes
we_tapBullFvg_15m = ifvg_only_1m and we_tapBullFvg_15m_live and not we_tapBullFvg_15m_live[1]
we_tapBearFvg_15m = ifvg_only_1m and we_tapBearFvg_15m_live and not we_tapBearFvg_15m_live[1]

//------------------------- 15m sweep event (from HL module)
we_sweepLow_15m  = hl_lowMitigatedCount  > hl_lowMitigatedCount[1]
we_sweepHigh_15m = hl_highMitigatedCount > hl_highMitigatedCount[1]

//------------------------- One-setup-per-key-level gate
// Each key event is identified by its source:
//   Tap   → we_lastBull15Time  / we_lastBear15Time   (the 15m FVG's own formation time;
//            stays constant even if price re-enters the same zone multiple times)
//   Sweep → we_lastSweepLowTime / we_lastSweepHighTime (unique per HL level deleted)
//
// A signal is blocked only when ALL currently active key events for that direction have
// already produced a signal. If even one active key event is new/unmatched, a fresh
// setup is allowed. This prevents re-tapping the same 15m FVG from resetting the gate.
var int we_consumedBullTapFvgT    = na  // we_lastBull15Time  when last LONG fired from tap
var int we_consumedBullSweepLowT  = na  // we_lastSweepLowTime when last LONG fired from sweep
var int we_consumedBearTapFvgT    = na  // we_lastBear15Time  when last SHORT fired from tap
var int we_consumedBearSweepHighT = na  // we_lastSweepHighTime when last SHORT fired from sweep

//------------------------- Update timestamps
if we_sweepLow_15m
    we_lastSweepLowTime := time
if we_sweepHigh_15m
    we_lastSweepHighTime := time
if we_tapBullFvg_15m
    we_lastTapBullTime := time
if we_tapBearFvg_15m
    we_lastTapBearTime := time

//------------------------- Recent checks
we_recentSweepLow  = not na(we_lastSweepLowTime)  and (time - we_lastSweepLowTime)  <= we_recent_ms
we_recentSweepHigh = not na(we_lastSweepHighTime) and (time - we_lastSweepHighTime) <= we_recent_ms
we_recentTapBull   = not na(we_lastTapBullTime)   and (time - we_lastTapBullTime)   <= we_recent_ms
we_recentTapBear   = not na(we_lastTapBearTime)   and (time - we_lastTapBearTime)   <= we_recent_ms

//------------------------- Identify the FIRST valid IFVG after the most recent key event
//
// Approach: scan the live IFVG arrays on EVERY BAR — no waiting flags, no ifvg_bull_created
// dependency. Among every IFVG whose inversion time (x_val) is >= the most recent key
// event time, pick the one with the SMALLEST x_val (earliest inversion). Break same-bar
// ties by choosing the LOWEST top for bull setups (deepest in the sweep, formed closest
// to the key level) or HIGHEST top for bear setups. Signal fires when close crosses that
// specific IFVG while the key event is still within the valid window.

// Targets are recalculated fresh every bar — no persistent state required.
we_targetBullTop = float(na)
we_targetBullBot = float(na)
we_targetBearTop = float(na)
we_targetBearBot = float(na)

// --- Bull: scan ifvg_bear_inv_ary ---
if we_recentSweepLow or we_recentTapBull
    _key_t = 0
    if we_recentSweepLow and not na(we_lastSweepLowTime)
        _key_t := math.max(_key_t, we_lastSweepLowTime)
    if we_recentTapBull and not na(we_lastTapBullTime)
        _key_t := math.max(_key_t, we_lastTapBullTime)
    if _key_t > 0 and ifvg_bear_inv_ary.size() > 0
        _bx = int(na)   // earliest x_val found so far
        _bt = float(na) // top of winning IFVG
        _bb = float(na) // bot of winning IFVG
        for _bi = 0 to ifvg_bear_inv_ary.size() - 1
            _bc = ifvg_bear_inv_ary.get(_bi)
            if not na(_bc.x_val) and _bc.x_val >= _key_t
                // prefer earlier inversion; break ties with lower top (closest to sweep)
                if na(_bx) or _bc.x_val < _bx or (_bc.x_val == _bx and _bc.top < _bt)
                    _bx := _bc.x_val
                    _bt := _bc.top
                    _bb := _bc.bot
        we_targetBullTop := _bt
        we_targetBullBot := _bb

// --- Bear: scan ifvg_bull_inv_ary ---
if we_recentSweepHigh or we_recentTapBear
    _key_t = 0
    if we_recentSweepHigh and not na(we_lastSweepHighTime)
        _key_t := math.max(_key_t, we_lastSweepHighTime)
    if we_recentTapBear and not na(we_lastTapBearTime)
        _key_t := math.max(_key_t, we_lastTapBearTime)
    if _key_t > 0 and ifvg_bull_inv_ary.size() > 0
        _bx = int(na)
        _bt = float(na)
        _bb = float(na)
        for _bi = 0 to ifvg_bull_inv_ary.size() - 1
            _bc = ifvg_bull_inv_ary.get(_bi)
            if not na(_bc.x_val) and _bc.x_val >= _key_t
                // prefer earlier inversion; break ties with higher top (closest to sweep)
                if na(_bx) or _bc.x_val < _bx or (_bc.x_val == _bx and _bc.top > _bt)
                    _bx := _bc.x_val
                    _bt := _bc.top
                    _bb := _bc.bot
        we_targetBearTop := _bt
        we_targetBearBot := _bb

// Signal: key event is still recent AND close crosses through the target IFVG
we_long_setup = (
    (we_recentSweepLow or we_recentTapBull) and
    not na(we_targetBullTop) and
    close > we_targetBullTop
)

we_short_setup = (
    (we_recentSweepHigh or we_recentTapBear) and
    not na(we_targetBearBot) and
    close < we_targetBearBot
)

//------------------------- Debounce + SAME-DIRECTION cooldown
we_sameDirCooldownBars = input.int(10, "WE MODEL: Same Direction Cooldown (bars)", minval=0, group="WE MODEL")

we_long_only  = we_long_setup and not we_short_setup
we_short_only = we_short_setup and not we_long_setup

we_long_edge  = we_long_only and not we_long_only[1]
we_short_edge = we_short_only and not we_short_only[1]

var int we_lastLongBar  = na
var int we_lastShortBar = na

we_long_inCooldown  = not na(we_lastLongBar)  and (bar_index - we_lastLongBar)  <= we_sameDirCooldownBars
we_short_inCooldown = not na(we_lastShortBar) and (bar_index - we_lastShortBar) <= we_sameDirCooldownBars

// Consumed = true when ALL active key events for this direction match a recorded signal.
// Re-tapping the SAME 15m FVG keeps the same we_lastBull15Time → stays consumed.
// Only a different FVG or a new HL sweep produces a fresh, unconsumed key event.
we_bullKeyConsumed = (
    (not we_recentTapBull  or we_lastBull15Time   == we_consumedBullTapFvgT)  and
    (not we_recentSweepLow or we_lastSweepLowTime == we_consumedBullSweepLowT)
)
we_bearKeyConsumed = (
    (not we_recentTapBear   or we_lastBear15Time    == we_consumedBearTapFvgT)   and
    (not we_recentSweepHigh or we_lastSweepHighTime == we_consumedBearSweepHighT)
)

we_long_fire  = we_long_edge  and not we_long_inCooldown  and not we_bullKeyConsumed
we_short_fire = we_short_edge and not we_short_inCooldown and not we_bearKeyConsumed

if we_long_fire
    we_lastLongBar := bar_index
    if we_recentTapBull   // stamp which FVG tap produced this signal
        we_consumedBullTapFvgT   := we_lastBull15Time
    if we_recentSweepLow  // stamp which sweep produced this signal
        we_consumedBullSweepLowT := we_lastSweepLowTime

if we_short_fire
    we_lastShortBar := bar_index
    if we_recentTapBear
        we_consumedBearTapFvgT    := we_lastBear15Time
    if we_recentSweepHigh
        we_consumedBearSweepHighT := we_lastSweepHighTime

// LONG: draw the target IFVG — we_targetBullTop/Bot computed just above on this same bar
if we_long_fire and ifvg_bear_inv_ary.size() > 0
    found_bull = false
    if not na(we_targetBullTop)
        for _i = 0 to ifvg_bear_inv_ary.size() - 1
            _c = ifvg_bear_inv_ary.get(_i)
            if _c.top == we_targetBullTop and _c.bot == we_targetBullBot
                ifvg_push_used(ifvg_used_long_ary, _c)
                found_bull := true
                break
    if not found_bull  // fallback: target removed before signal fired
        ifvg_push_used(ifvg_used_long_ary, array.get(ifvg_bear_inv_ary, ifvg_bear_inv_ary.size() - 1))

// SHORT: draw the target IFVG
if we_short_fire and ifvg_bull_inv_ary.size() > 0
    found_bear = false
    if not na(we_targetBearTop)
        for _i = 0 to ifvg_bull_inv_ary.size() - 1
            _c = ifvg_bull_inv_ary.get(_i)
            if _c.top == we_targetBearTop and _c.bot == we_targetBearBot
                ifvg_push_used(ifvg_used_short_ary, _c)
                found_bear := true
                break
    if not found_bear  // fallback: target removed before signal fired
        ifvg_push_used(ifvg_used_short_ary, array.get(ifvg_bull_inv_ary, ifvg_bull_inv_ary.size() - 1))

//------------------------- Alerts + Markers
alertcondition(we_long_fire,  "WE MODEL LONG",  "WE MODEL LONG setup")
alertcondition(we_short_fire, "WE MODEL SHORT", "WE MODEL SHORT setup")

//==================================================================================================
//====================== WE MODEL: ENTRY LINE + LONG/SHORT TEXT (VISIBLE) =========================
//==================================================================================================

entry_enabled     = input.bool(true, "ENTRY: Show Entry Line + Text", group="WE MODEL")
entry_extendBars  = input.int(7,     "ENTRY: Extend (bars)", minval=1, maxval=50, group="WE MODEL")

entryLongColor  = color.blue
entryShortColor = color.red

is1m  = timeframe.isminutes and timeframe.multiplier == 1
barMs = timeframe.multiplier * 60000

if entry_enabled and is1m

    //================ LONG =================
    if we_long_fire

        entryPrice = close

        line.new(
            x1 = time,
            y1 = entryPrice,
            x2 = time + (entry_extendBars * barMs),
            y2 = entryPrice,
            xloc = xloc.bar_time,
            extend = extend.none,
            color = entryLongColor,
            style = line.style_solid,
            width = 3
        )

        label.new(
            x = time + (entry_extendBars * barMs),
            y = entryPrice,
            text = "LONG",
            xloc = xloc.bar_time,
            style = label.style_none,
            textcolor = entryLongColor,
            size = size.normal
        )

    //================ SHORT =================
    if we_short_fire

        entryPrice = close

        line.new(
            x1 = time,
            y1 = entryPrice,
            x2 = time + (entry_extendBars * barMs),
            y2 = entryPrice,
            xloc = xloc.bar_time,
            extend = extend.none,
            color = entryShortColor,
            style = line.style_solid,
            width = 3
        )

        label.new(
            x = time + (entry_extendBars * barMs),
            y = entryPrice,
            text = "SHORT",
            xloc = xloc.bar_time,
            style = label.style_none,
            textcolor = entryShortColor,
            size = size.normal
        )

//------------------------- SL Inputs
sl_enabled      = input.bool(true, "SL: Show Stop Loss", group="WE MODEL")
sl_padTicks     = input.int(0,     "SL: Padding (ticks)", minval=0, group="WE MODEL")
sl_dashedLine   = input.bool(true, "SL: Dashed Line", group="WE MODEL")
sl_showLabel    = input.bool(true, "SL: Show 'SL' Tag", group="WE MODEL")
sl_labelOffset  = input.int(0,     "SL: Label Vertical Offset (ticks)", minval=0, group="WE MODEL")

pad      = sl_padTicks * syminfo.mintick
lblPad   = sl_labelOffset * syminfo.mintick

//------------------------- 2-candle swing detection
bull_1 = close[1] > open[1]
bear_1 = close[1] < open[1]
bull_0 = close > open
bear_0 = close < open

swingHighNow = bull_1 and bear_0
swingLowNow  = bear_1 and bull_0

//------------------------- Store most recent swings
var float sl_lastSwingHigh  = na
var int   sl_lastSwingHighT = na
var float sl_lastSwingLow   = na
var int   sl_lastSwingLowT  = na

if sl_enabled and is1m
    if swingHighNow
        sl_lastSwingHigh  := high[1]
        sl_lastSwingHighT := time[1]

    if swingLowNow
        sl_lastSwingLow  := low[1]
        sl_lastSwingLowT := time[1]

//------------------------- SL prices
sl_long_price  = (sl_enabled and we_long_fire  and not na(sl_lastSwingLow))  ? (sl_lastSwingLow  - pad) : na
sl_short_price = (sl_enabled and we_short_fire and not na(sl_lastSwingHigh)) ? (sl_lastSwingHigh + pad) : na

//==================================================================================================
//============================ DRAW SUBTLE SL (NO BLOCKY LABELS) ===================================
//==================================================================================================

slColor = color.new(color.gray, 60)

if sl_enabled and is1m
    // LONG STOP LOSS
    if we_long_fire and not na(sl_long_price) and not na(sl_lastSwingLowT)
        line.new(
            x1 = sl_lastSwingLowT,
            y1 = sl_long_price,
            x2 = time + (3 * 60000),
            y2 = sl_long_price,
            xloc = xloc.bar_time,
            extend = extend.none,
            color = slColor,
            style = line.style_dotted,
            width = 1
        )

        if sl_showLabel
            label.new(
                x = time, y = sl_long_price,
                text = "SL",
                xloc = xloc.bar_time,
                style = label.style_none,
                textcolor = color.white,  // FIX: was color.black — invisible on dark backgrounds
                size = size.small
            )

    // SHORT STOP LOSS
    if we_short_fire and not na(sl_short_price) and not na(sl_lastSwingHighT)
        line.new(
            x1 = sl_lastSwingHighT,
            y1 = sl_short_price,
            x2 = time + (3 * 60000),
            y2 = sl_short_price,
            xloc = xloc.bar_time,
            extend = extend.none,
            color = slColor,
            style = line.style_dotted,
            width = 1
        )
    
        if sl_showLabel
            label.new(
                x = time, y = sl_short_price,
                text = "SL",
                xloc = xloc.bar_time,
                style = label.style_none,
                textcolor = color.white,  // FIX: was color.black — invisible on dark backgrounds
                size = size.small
            )

//==================================================================================================
//=========================== MNQ CONTRACT LABEL (NO ALERTS) =======================================
//==================================================================================================

mnq_preferredRisk = input.float(100, "MNQ: Preferred Risk ($)", step=10, group="MNQ RISK")
mnq_showMNQLabel  = input.bool(true, "MNQ: Show Contracts Label", group="MNQ RISK")

mnq_dollarsPerPoint = 2.0

mnq_stopPts_long  = (we_long_fire  and not na(sl_long_price))  ? math.abs(close - sl_long_price)   : na
mnq_stopPts_short = (we_short_fire and not na(sl_short_price)) ? math.abs(sl_short_price - close) : na

mnq_raw_long  = (not na(mnq_stopPts_long)  and mnq_stopPts_long  > 0) ? (mnq_preferredRisk / (mnq_stopPts_long  * mnq_dollarsPerPoint)) : na
mnq_raw_short = (not na(mnq_stopPts_short) and mnq_stopPts_short > 0) ? (mnq_preferredRisk / (mnq_stopPts_short * mnq_dollarsPerPoint)) : na

mnq_long_contracts  = not na(mnq_raw_long)  ? math.floor(mnq_raw_long  + 0.5) : na
mnq_short_contracts = not na(mnq_raw_short) ? math.floor(mnq_raw_short + 0.5) : na

mnq_long_contracts  := not na(mnq_long_contracts)  ? math.max(mnq_long_contracts,  0) : na
mnq_short_contracts := not na(mnq_short_contracts) ? math.max(mnq_short_contracts, 0) : na

if mnq_showMNQLabel and sl_enabled and is1m
    if we_long_fire and not na(mnq_long_contracts) and not na(sl_long_price)
        label.new(
            x = time,
            y = sl_long_price + (2 * syminfo.mintick),
            xloc = xloc.bar_time,
            text = "MNQ: " + str.tostring(mnq_long_contracts),
            style = label.style_label_up,
            size = size.tiny,
            textcolor = color.white,
            color = color.new(color.blue, 0)
        )

    if we_short_fire and not na(mnq_short_contracts) and not na(sl_short_price)
        label.new(
            x = time,
            y = sl_short_price + (2 * syminfo.mintick),
            xloc = xloc.bar_time,
            text = "MNQ: " + str.tostring(mnq_short_contracts),
            style = label.style_label_down,
            size = size.tiny,
            textcolor = color.white,
            color = color.new(color.red, 0)
        )

//==================================================================================================
//====================================== SMT MODULE ================================================
//==================================================================================================

compSymbol         = input.symbol("CME_MINI:ES1!", "Comparison Symbol", group="SMT")
showBullishSMT     = input.bool(true, "Show Bullish SMT", group="SMT")
showBearishSMT     = input.bool(true, "Show Bearish SMT", group="SMT")
deleteOld          = input.bool(false, "Delete Previous Drawings", group="SMT")
pivotLen           = input.int(3, "Pivot Length", minval=1, group="SMT")

compHigh = request.security(compSymbol, timeframe.period, high)
compLow  = request.security(compSymbol, timeframe.period, low)

ph  = ta.pivothigh(high, pivotLen, pivotLen)
pl  = ta.pivotlow(low, pivotLen, pivotLen)
cph = ta.pivothigh(compHigh, pivotLen, pivotLen)
cpl = ta.pivotlow(compLow, pivotLen, pivotLen)

var float lastMainHigh    = na
var float prevMainHigh    = na
var int   lastMainHighBar = na
var int   prevMainHighBar = na

var float lastCompHigh = na
var float prevCompHigh = na

var float lastMainLow    = na
var float prevMainLow    = na
var int   lastMainLowBar = na
var int   prevMainLowBar = na

var float lastCompLow = na
var float prevCompLow = na

if not na(ph)
    prevMainHigh    := lastMainHigh
    prevMainHighBar := lastMainHighBar
    lastMainHigh    := ph
    lastMainHighBar := bar_index - pivotLen

if not na(cph)
    prevCompHigh := lastCompHigh
    lastCompHigh := cph

if not na(pl)
    prevMainLow    := lastMainLow
    prevMainLowBar := lastMainLowBar
    lastMainLow    := pl
    lastMainLowBar := bar_index - pivotLen

if not na(cpl)
    prevCompLow := lastCompLow
    lastCompLow := cpl

var line[]  smtLines  = array.new_line()
var label[] smtLabels = array.new_label()

f_clear_drawings() =>
    if deleteOld
        if array.size(smtLines) > 0
            for i = array.size(smtLines) - 1 to 0
                line.delete(array.get(smtLines, i))
        if array.size(smtLabels) > 0
            for i = array.size(smtLabels) - 1 to 0
                label.delete(array.get(smtLabels, i))
        array.clear(smtLines)
        array.clear(smtLabels)

bearishSMT = showBearishSMT and
     not na(prevMainHigh) and not na(lastMainHigh) and
     not na(prevCompHigh) and not na(lastCompHigh) and
     lastMainHigh > prevMainHigh and
     lastCompHigh <= prevCompHigh

bullishSMT = showBullishSMT and
     not na(prevMainLow) and not na(lastMainLow) and
     not na(prevCompLow) and not na(lastCompLow) and
     lastMainLow < prevMainLow and
     lastCompLow >= prevCompLow

bearishSMT_now = bearishSMT and bar_index == lastMainHighBar + pivotLen
bullishSMT_now = bullishSMT and bar_index == lastMainLowBar + pivotLen

if bearishSMT_now
    f_clear_drawings()
    ln = line.new(
        x1 = prevMainHighBar,
        y1 = prevMainHigh,
        x2 = lastMainHighBar,
        y2 = lastMainHigh,
        color = color.red,
        width = 2
    )
    lb = label.new(
        x = lastMainHighBar,
        y = lastMainHigh,
        text = "SMT",
        style = label.style_label_down,
        textcolor = color.white,
        color = color.red,
        size = size.tiny
    )
    array.push(smtLines, ln)
    array.push(smtLabels, lb)

if bullishSMT_now
    f_clear_drawings()
    ln = line.new(
        x1 = prevMainLowBar,
        y1 = prevMainLow,
        x2 = lastMainLowBar,
        y2 = lastMainLow,
        color = color.lime,
        width = 2
    )
    lb = label.new(
        x = lastMainLowBar,
        y = lastMainLow,
        text = "SMT",
        style = label.style_label_up,
        textcolor = color.black,
        color = color.lime,
        size = size.tiny
    )
    array.push(smtLines, ln)
    array.push(smtLabels, lb)

//==================================================================================================
//=========================== OPENING PRICES (WE MODEL) ============================================
//==================================================================================================
var float weeklyOpen        = na
var float dailyMidnightOpen = na
var float open830           = na
var float open930           = na
var float open1330          = na

nyHour   = hour(time, "America/New_York")
nyMinute = minute(time, "America/New_York")
newDay   = ta.change(time("D", "America/New_York")) != 0
newWeek  = ta.change(time("W")) != 0
curMins  = nyHour * 60 + nyMinute

// Weekly open (Sunday 18:00 NY) and midnight open both reset at the start of each new week
if newWeek
    weeklyOpen        := na
    dailyMidnightOpen := na

// Capture Sunday 18:00 NY as the weekly opening price
nyDow = dayofweek(time, "America/New_York")
if nyDow == dayofweek.sunday and nyHour == 18 and nyMinute == 0
    weeklyOpen := open

// 8:30, 9:30, and 13:30 opens are day-scoped — reset them each trading day
if newDay
    open830  := na
    open930  := na
    open1330 := na

if nyHour == 0 and nyMinute == 0
    dailyMidnightOpen := open

if nyHour == 8 and nyMinute == 30
    open830 := open

if nyHour == 9 and nyMinute == 30
    open930 := open

if nyHour == 13 and nyMinute == 30
    open1330 := open

isAsia         = curMins >= 18 * 60 or curMins <= 1 * 60 + 59
isLondon       = curMins >= 2 * 60  and curMins <= 5 * 60 + 59
isNyOpen       = curMins >= 6 * 60  and curMins <= 8 * 60 + 29
isNyPremarket  = curMins >= 8 * 60 + 30 and curMins <= 9 * 60 + 29
isNyAM         = curMins >= 9 * 60 + 30 and curMins <= 11 * 60 + 29
isLunch        = curMins >= 11 * 60 + 30 and curMins <= 13 * 60 + 29
isNyPM         = curMins >= 13 * 60 + 30 and curMins <= 14 * 60 + 59
isFinalHour    = curMins >= 15 * 60 and curMins <= 16 * 60

aboveTodayOpens = (
    (na(weeklyOpen)        or close > weeklyOpen)        and
    (na(dailyMidnightOpen) or close > dailyMidnightOpen) and
    (na(open830) or close > open830) and
    (na(open930) or close > open930) and
    (na(open1330) or close > open1330)
)
belowTodayOpens = (
    (na(weeklyOpen)        or close < weeklyOpen)        and
    (na(dailyMidnightOpen) or close < dailyMidnightOpen) and
    (na(open830) or close < open830) and
    (na(open930) or close < open930) and
    (na(open1330) or close < open1330)
)

//==================================================================================================
//=========================== WE MODEL GRADE TOOLTIP ===============================================
//==================================================================================================

grade_show_tooltip = input.bool(true, "GRADE: Show Hover Tooltip", group="WE MODEL GRADE")

sessionName = (
     isAsia        ? "ASIA" :
     isLondon      ? "LONDON" :
     isNyOpen      ? "NY OPEN" :
     isNyPremarket ? "NY PRE MARKET" :
     isNyAM        ? "NY AM" :
     isLunch       ? "SHITTY LUNCH" :
     isNyPM        ? "NY PM" :
     isFinalHour   ? "FINAL HOUR MACRO" :
     "OFF SESSION"
)
sessionIcon = (
     isAsia        ? "🌙" :
     isLondon      ? "🇬🇧" :
     isNyOpen      ? "🔔" :
     isNyPremarket ? "📈" :
     isNyAM        ? "🗽" :
     isLunch       ? "🍔" :
     isNyPM        ? "⚡" :
     isFinalHour   ? "🔥" :
     "•"
)

// Count how many opening prices exist at this moment (denominator for display)
we_available_opens() =>
    int total = 0
    total += not na(weeklyOpen)        ? 1 : 0
    total += not na(dailyMidnightOpen) ? 1 : 0
    total += not na(open830)           ? 1 : 0
    total += not na(open930)           ? 1 : 0
    total += not na(open1330)          ? 1 : 0
    total

we_count_above_opens(_price) =>
    int cnt = 0
    cnt += not na(weeklyOpen)        and _price > weeklyOpen        ? 1 : 0
    cnt += not na(dailyMidnightOpen) and _price > dailyMidnightOpen ? 1 : 0
    cnt += not na(open830)           and _price > open830           ? 1 : 0
    cnt += not na(open930)           and _price > open930           ? 1 : 0
    cnt += not na(open1330)          and _price > open1330          ? 1 : 0
    cnt

we_count_below_opens(_price) =>
    int cnt = 0
    cnt += not na(weeklyOpen)        and _price < weeklyOpen        ? 1 : 0
    cnt += not na(dailyMidnightOpen) and _price < dailyMidnightOpen ? 1 : 0
    cnt += not na(open830)           and _price < open830           ? 1 : 0
    cnt += not na(open930)           and _price < open930           ? 1 : 0
    cnt += not na(open1330)          and _price < open1330          ? 1 : 0
    cnt

grade_bullishSMT = bullishSMT_now
grade_bearishSMT = bearishSMT_now

we_long_grade(_price, _bullishSMT_now) =>
    belowCount = we_count_below_opens(_price)
    string grade = "C"
    if belowCount >= 2
        grade := _bullishSMT_now ? "A+" : "A"
    else if belowCount >= 1
        grade := _bullishSMT_now ? "B+" : "B"
    else
        grade := _bullishSMT_now ? "C+" : "C"
    grade

we_short_grade(_price, _bearishSMT_now) =>
    aboveCount = we_count_above_opens(_price)
    string grade = "C"
    if aboveCount >= 2
        grade := _bearishSMT_now ? "A+" : "A"
    else if aboveCount >= 1
        grade := _bearishSMT_now ? "B+" : "B"
    else
        grade := _bearishSMT_now ? "C+" : "C"
    grade

we_long_tooltip(_price, _bullishSMT_now) =>
    belowCount = we_count_below_opens(_price)
    totalOpens = we_available_opens()
    grade = we_long_grade(_price, _bullishSMT_now)

    (
        "Grade: " + grade + "\n" +
        "✓ IFVG\n" +
        "✓ Key Level\n" +
        "Openings below price: " + str.tostring(belowCount) + "/" + str.tostring(totalOpens) + "\n" +
        "Bullish SMT: " + (_bullishSMT_now ? "Yes" : "No") + "\n" +
        "SESSION: " + sessionIcon + " " + sessionName
    )

we_short_tooltip(_price, _bearishSMT_now) =>
    aboveCount = we_count_above_opens(_price)
    totalOpens = we_available_opens()
    grade = we_short_grade(_price, _bearishSMT_now)

    (
        "Grade: " + grade + "\n" +
        "✓ IFVG\n" +
        "✓ Key Level\n" +
        "Openings above price: " + str.tostring(aboveCount) + "/" + str.tostring(totalOpens) + "\n" +
        "Bearish SMT: " + (_bearishSMT_now ? "Yes" : "No") + "\n" +
        "SESSION: " + sessionIcon + " " + sessionName
    )

if grade_show_tooltip and is1m

    offsetX = entry_extendBars * barMs

    if we_long_fire
        longTip = we_long_tooltip(close, bullishSMT_now)

        label.new(
            x = time + offsetX + (2 * barMs),
            y = close,
            xloc = xloc.bar_time,
            text = "●",
            style = label.style_label_center,
            textcolor = color.blue,
            color = color.new(color.blue, 80),
            size = size.large,
            tooltip = longTip
        )

    if we_short_fire
        shortTip = we_short_tooltip(close, bearishSMT_now)

        label.new(
            x = time + offsetX + (2 * barMs),
            y = close,
            xloc = xloc.bar_time,
            text = "●",
            style = label.style_label_center,
            textcolor = color.red,
            color = color.new(color.red, 80),
            size = size.large,
            tooltip = shortTip
        )
